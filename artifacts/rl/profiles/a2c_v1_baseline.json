{
  "profile_id": "a2c_v1_baseline",
  "description": "SB3 A2C baseline — 경량 on-policy, 하락장 강점",
  "algorithm": "a2c",
  "state_version": "sb3_a2c",
  "trainer_params": {
    "algorithm": "a2c",
    "lookback": 20,
    "num_episodes": 15,
    "trade_penalty_bps": 2,
    "opportunity_cost_factor": 0.5,
    "long_loss_penalty": 0.9,
    "net_arch": [64, 64],
    "learning_rate": 7e-4,
    "gamma": 0.95,
    "n_steps_a2c": 5,
    "ent_coef_a2c": 0.01,
    "vf_coef": 0.5,
    "num_seeds": 3,
    "random_seed": 42
  },
  "dataset": {
    "default_source": "yfinance",
    "default_range": "10y",
    "default_train_ratio": 0.7,
    "adaptive_ratios": [0.5, 0.6, 0.7, 0.8],
    "bandit_epsilon": 0.2,
    "min_history_points": 40
  },
  "evaluation": {
    "min_approval_return_pct": 5.0,
    "max_drawdown_limit_pct": -50.0
  },
  "hyperopt": {
    "enabled": false,
    "n_trials": 50,
    "timeout_seconds": null
  }
}
