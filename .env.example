# ============================================================
# Alpha Trading System — 환경 변수 템플릿
# 이 파일을 복사하여 .env 로 사용하세요: cp .env.example .env
# ⚠️  .env 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# ── Git / GitHub ───────────────────────────────────────────────────────────────────────────
# GitHub Personal Access Token (repo 권한 필요)
# 발급: https://github.com/settings/tokens → "Generate new token (classic)" → repo 체크
# AI 에이전트가 git push 시 이 값을 읽어 인증에 사용합니다 (CLAUDE.md 참고)
GITHUB_TOKEN=ghp_여기에토큰값_입력

# ── App ────────────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000

# ── Database / Redis ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://alpha_user:alpha_pass@localhost:5432/alpha_db
REDIS_URL=redis://localhost:6379/0

# ── S3 / Object Storage ──────────────────────────────────────────────────────
# 앱 코드(s3_client.py)는 환경변수만으로 MinIO ↔ R2를 전환합니다.
# 배포 방식(Docker Compose / K3s)과 무관하게 아래 값만 교체하면 됩니다.
#
# 로컬/K3s (MinIO):
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=alpha-datalake
S3_REGION=us-east-1
#
# 클라우드 (Cloudflare R2): 위 값을 아래로 교체.
# R2 버킷은 API로 생성 불가 — Cloudflare 콘솔에서 사전 생성 필요.
# (s3_client.py의 ensure_bucket()이 R2의 403/409를 graceful 처리함)
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY=<R2 Access Key ID>
# S3_SECRET_KEY=<R2 Secret Access Key>
# S3_BUCKET_NAME=alpha-datalake
# S3_REGION=auto

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
# 기본 admin 시드는 보안을 위해 기본값을 false 로 둡니다.
# 필요할 때에만 true 로 변경하고, 아래 email/password 를 반드시 실제 값으로 변경하세요.
DEFAULT_ADMIN_SEED_ENABLED=false
DEFAULT_ADMIN_EMAIL=CHANGE_ME_ADMIN@example.com
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── LLM 인증 ─────────────────────────────────────────────────────────────────
# 인증 우선순위: CLI 구독 > API Key SDK
# 정상 시 구독으로 동작, CLI 토큰 만료 시 자동으로 API Key SDK fallback.
#
# Claude:
#   로컬: CLI 모드 (claude 바이너리 + Max 구독). ~/.claude를 Docker에 마운트.
#   클라우드: setup-token으로 1회 인증 → CLAUDE_CODE_OAUTH_TOKEN 환경변수 설정 (1년 유효).
#   fallback: ANTHROPIC_API_KEY 설정 시 SDK 종량제로 자동 전환.
ANTHROPIC_CLI_COMMAND=claude
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=  # 클라우드 headless 인증 시 설정

# GPT / Codex:
#   로컬: Codex CLI 모드 (codex 바이너리 + ChatGPT Plus 구독). ~/.codex를 Docker에 마운트.
#   클라우드: codex login --device-auth (비대화형, ~8일 미사용 시 만료).
#   fallback: OPENAI_API_KEY 설정 시 SDK 종량제로 자동 전환.
OPENAI_API_KEY=

# Gemini:
#   OAuth(ADC) 모드. 로컬/클라우드 동일.
#   로컬: gcloud auth application-default login. ~/.config/gcloud를 Docker에 마운트.
#   클라우드: 서비스 계정 JSON 파일 마운트 (GOOGLE_APPLICATION_CREDENTIALS).
GOOGLE_APPLICATION_CREDENTIALS=

# LLM 공통
LLM_CLI_TIMEOUT_SECONDS=90
LLM_DAILY_PROVIDER_LIMIT=30

# ── KIS Developers 공통 fallback (legacy) ──────────────────────────────────────────────────
# split key가 비어 있을 때 fallback으로 사용됩니다.
KIS_APP_KEY=PSXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 계좌번호 형식: 8자리 계좌번호 + 2자리 상품코드 (예: 50123456-01 -> 5012345601)
KIS_ACCOUNT_NUMBER=5012345601
KIS_IS_PAPER_TRADING=true

# ── KIS Paper 계좌 (권장: 명시적으로 분리) ──────────────────────────────────────────────────
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NUMBER=

# ── KIS Real 계좌 (권장: 명시적으로 분리) ────────────────────────────────────────────────────
KIS_REAL_APP_KEY=
KIS_REAL_APP_SECRET=
KIS_REAL_ACCOUNT_NUMBER=

# ── Broker backends ───────────────────────────────────────────────────────────────────────
PAPER_BROKER_BACKEND=internal
REAL_BROKER_BACKEND=kis
KIS_REQUEST_TIMEOUT_SECONDS=15

# ── Telegram Bot ───────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── Strategy / Readiness ───────────────────────────────────────────────────────────────────
STRATEGY_BLEND_RATIO=0.50
STRATEGY_BLEND_WEIGHTS={"A": 0.30, "B": 0.30, "RL": 0.20, "S": 0.20}
# 성과 기반 동적 가중치 조정 (opt-in, 기본 off)
DYNAMIC_BLEND_WEIGHTS_ENABLED=false
DYNAMIC_BLEND_LOOKBACK_DAYS=30
DYNAMIC_BLEND_MIN_WEIGHT=0.05
STRATEGY_A_ROLLING_DAYS=5
STRATEGY_A_MIN_SAMPLES=3
STRATEGY_B_MAX_ROUNDS=2
STRATEGY_B_CONSENSUS_THRESHOLD=0.67
SEARCH_MAX_CONCURRENT=3
SEARCH_CATEGORIES=news
SEARCH_MAX_SOURCES=5
REAL_TRADING_CONFIRMATION_CODE=CONFIRM_REAL_TRADING_2026
READINESS_REQUIRED_PAPER_DAYS=30
READINESS_AUDIT_MAX_AGE_DAYS=7

# ── Orchestrator Worker ────────────────────────────────────────────────────────────────────
ORCH_MODE=blend
ORCH_TICKERS=
ORCH_INTERVAL_SECONDS=600
ORCH_RUN_ONCE=false
ORCH_ENABLE_DAILY_REPORT=false
ORCH_DAILY_REPORT_HOUR=17
ORCH_DAILY_REPORT_MINUTE=10
ORCH_TOURNAMENT_ROLLING_DAYS=
ORCH_TOURNAMENT_MIN_SAMPLES=
ORCH_CONSENSUS_ROUNDS=
ORCH_CONSENSUS_THRESHOLD=

# ── Screener / Collector 확장 ─────────────────────────────────────────────────────────────────
COLLECTOR_DAILY_LIMIT=100              # 일봉 수집 종목 수 (시가총액 상위 N, 기본 100)
MAX_SCREENED_TICKERS=10                # 스크리너 통과 후 전략 실행 최대 종목 (기본 10)
SCREENER_VOLUME_SURGE_RATIO=2.0        # 거래량 급등 기준 (20일 평균 대비 N배)
SCREENER_CHANGE_PCT_THRESHOLD=3.0      # 가격 변동률 기준 (±N%)

# ── Blog Auto-Posting (Google Blogger) ─────────────────────────────────────────────────────
BLOGGER_BLOG_ID=
BLOGGER_CLIENT_ID=
BLOGGER_CLIENT_SECRET=
BLOGGER_REFRESH_TOKEN=

# ── WebSocket Tick Collection ─────────────────────────────────────────────────────────────
# 장중 실시간 틱 배치 flush 설정
WS_TICK_BATCH_SIZE=100          # 버퍼 최대 건수 (1~2000)
WS_TICK_FLUSH_INTERVAL=1.0      # 타임아웃 flush 주기, 초 (0.1~30.0)
WS_TICK_TICKERS=005930,000660,035420  # 실시간 틱 수집 대상 종목 (쉼표 구분)

# ── Logging ────────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
