# ============================================================
# Alpha Trading System — 환경 변수 템플릿
# 이 파일을 복사하여 .env 로 사용하세요: cp .env.example .env
# ⚠️  .env 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://alpha_user:alpha_pass@localhost:5432/alpha_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (JWT) ───────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# ── LLM APIs ─────────────────────────────────────────────────
# Claude: CLI 우선, SDK 폴백
ANTHROPIC_API_KEY=sk-ant-...

# GPT-4o: Strategy A Tournament 인스턴스 3,4 + Strategy B Challenger 1
OPENAI_API_KEY=sk-...

# Gemini: Strategy A Tournament 인스턴스 5 + Strategy B Challenger 2
GEMINI_API_KEY=AI...

# ── KIS Developers (한국투자증권) ────────────────────────────
# https://apiportal.koreainvestment.com 에서 앱 등록 후 발급
KIS_APP_KEY=PSXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 계좌번호 (예: 50123456-01 → 5012345601)
KIS_ACCOUNT_NUMBER=5012345601
# true = 페이퍼 트레이딩, false = 실거래 (기본값: true — 절대 함부로 false 변경 금지!)
KIS_IS_PAPER_TRADING=true

# ── Telegram Bot ─────────────────────────────────────────────
# @BotFather에서 봇 생성 후 발급
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 개인 채팅 또는 그룹 채팅 ID (음수일 수 있음)
TELEGRAM_CHAT_ID=123456789

# ── Strategy ─────────────────────────────────────────────────
# 0.0 = Strategy A 100%, 1.0 = Strategy B 100%, 0.5 = 50/50 블렌드
STRATEGY_BLEND_RATIO=0.50
# Strategy B 최대 토론 라운드 수 (1~5)
STRATEGY_B_MAX_ROUNDS=2
# Strategy B 합의 confidence 임계치 (0.0~1.0)
STRATEGY_B_CONSENSUS_THRESHOLD=0.67

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
